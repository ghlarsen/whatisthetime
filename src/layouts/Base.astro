---
// src/layouts/Base.astro
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  faqs?: { q: string; a: string }[];
  ogImage?: string;
}
const {
  title,
  description = 'What time is it anywhere in the world? Live clocks for 990 cities with timezone info, DST dates, and meeting planner.',
  canonical,
  faqs,
  ogImage = 'https://whatisthetime.now/og.png',
} = Astro.props;

const faqSchema = faqs?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      // Strip HTML tags for clean schema text
      "text": a.replace(/<[^>]+>/g, ''),
    },
  })),
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}

  <!-- Favicon + icons -->
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="whatisthetime.now" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- WebPage schema -->
  {canonical && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonical,
      "publisher": {
        "@type": "Organization",
        "name": "whatisthetime.now",
        "url": "https://whatisthetime.now",
      },
    })} />
  )}

  <!-- FAQPage schema — huge for GEO (Perplexity, ChatGPT Search, Gemini) -->
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <!-- Prevent theme flash: read localStorage before paint -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefer = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || prefer);
    })();
  </script>

  <!-- Bricolage Grotesque variable font (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ─── Design System ───────────────────────────────────────────────
     *
     *  Josef Muller-Brockmann: "The grid system is an aid, not a
     *  guarantee. It permits a number of possible uses and each
     *  designer can look for a solution appropriate to his personal
     *  style. But one must learn how to use the grid; it is an art
     *  that requires practice."
     *
     *  All tokens defined here. Never hardcode values in components.
     *
     * ──────────────────────────────────────────────────────────────── */

    :root {
      /* ── Typography ── */

      /* Scale: 5 steps from micro to display */
      --t-xs:       0.6875rem;                /* 11px  captions, offsets, dots    */
      --t-sm:       0.75rem;                  /* 12px  labels, chips, nav         */
      --t-base:     0.875rem;                 /* 14px  body, FAQ, descriptions    */
      --t-panel:    2.25rem;                  /* 36px  grid clocks (compact)      */
      --t-display:  clamp(3rem, 14vw, 9rem);  /* fluid hero clocks               */

      /* Families: three stacks, one truth */
      --font-display:  'Bricolage Grotesque', sans-serif;
      --font-body:     system-ui, -apple-system, sans-serif;
      --font-mono:     ui-monospace, 'SF Mono', 'Fira Code', monospace;

      /* ── Spacing ── */
      --page-pad:   1.75rem;                  /* 28px  horizontal page gutter     */
    }

    @media (max-width: 500px) {
      :root {
        --page-pad: 1rem;                     /* 16px  tighter on mobile          */
      }
    }

    /* ── Colour: Dark ── */
    :root[data-theme="dark"] {
      --bg:            #0a0a0a;
      --bg-subtle:     #111111;
      --text:          #ffffff;
      --text-muted:    #f2f5f4;
      --text-dim:      #f2f5f4;
      --border:        #222222;
      --bar-empty:     #5a5a5a;
      --bar-work:      #1e6640;
      --footer-city:   #606060;
      --footer-region: #999999;
    }

    /* ── Colour: Light ── */
    :root[data-theme="light"] {
      --bg:            #ffffff;
      --bg-subtle:     #fafafa;
      --text:          #111111;
      --text-muted:    #191932;
      --text-dim:      #5a5a8a;   /* WCAG AA 4.6:1 on white */
      --border:        #ebebeb;
      --bar-empty:     #b8b8b8;
      --bar-work:      #6dba8e;
      --footer-city:   #f2f5f4;
      --footer-region: #8a8a8a;
    }

    html {
      overflow-x: hidden; /* prevent horizontal scroll on mobile */
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      min-height: 100vh;
      transition: background 0.3s, color 0.3s;
      overflow-x: hidden;
      max-width: 100vw;
    }

    /* Screen reader only (visually hidden but accessible) */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* Focus rings for keyboard navigation */
    :focus-visible {
      outline: 2px solid var(--text-muted);
      outline-offset: 2px;
      border-radius: 2px;
    }

    /* Skip to content link */
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      background: var(--text);
      color: var(--bg);
      padding: 8px 16px;
      font-size: var(--t-sm);
      z-index: 1000;
      border-radius: 0 0 4px 4px;
      text-decoration: none;
      transition: top 0.15s;
    }
    .skip-link:focus {
      top: 0;
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <main id="main-content">
    <slot />
  </main>
</body>
</html>
