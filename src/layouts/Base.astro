---
// src/layouts/Base.astro
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  faqs?: { q: string; a: string }[];
  ogImage?: string;
}
const {
  title,
  description = 'What time is it anywhere in the world? Live clocks for 990 cities with timezone info, DST dates, and meeting planner.',
  canonical,
  faqs,
  ogImage = 'https://whatisthetime.now/og.png',
} = Astro.props;

const faqSchema = faqs?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": {
      "@type": "Answer",
      // Strip HTML tags for clean schema text
      "text": a.replace(/<[^>]+>/g, ''),
    },
  })),
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}

  <!-- Favicon + theme color -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="whatisthetime.now" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- WebPage schema -->
  {canonical && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonical,
      "publisher": {
        "@type": "Organization",
        "name": "whatisthetime.now",
        "url": "https://whatisthetime.now",
      },
    })} />
  )}

  <!-- FAQPage schema — huge for GEO (Perplexity, ChatGPT Search, Gemini) -->
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <!-- Prevent theme flash: read localStorage before paint -->
  <script is:inline>
    (function() {
      const stored = localStorage.getItem('theme');
      const prefer = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || prefer);
    })();
  </script>

  <!-- Bricolage Grotesque variable font (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200..800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Type scale — four levels, defined once ─────────────────────
       L1 micro    11px               captions, offsets, status dots
       L2 label    12px               city names, chips, buttons, nav
       L3 body     14px               FAQ, facts, dates, descriptions
       L4a panel   36px               compact grid clocks (meeting, world grid)
       L4b display clamp(3–9rem,14vw) hero/page clocks — fluid, one token
    ─────────────────────────────────────────────────────────────── */
    :root {
      --t-xs:      0.6875rem;               /* 11px — L1 micro */
      --t-sm:      0.75rem;                /* 12px — L2 label */
      --t-base:    0.875rem;               /* 14px — L3 body */
      --t-panel:   2.25rem;                /* 36px — L4a compact grid clock */
      --t-display: clamp(3rem, 14vw, 9rem); /* L4b hero/page clock — fluid */
      --page-pad:  1.75rem;                /* 28px — horizontal page padding */
    }

    @media (max-width: 500px) {
      :root { --page-pad: 1rem; } /* 16px on mobile */
    }

    /* ── Grey system ─────────────────────────────────────────────────
       Dark mode: greys are LIGHT — near-white reads crisply on black.
         --text-muted: #b0b0b0  8.5:1  secondary text, city names
         --text-dim:   #666666  3.9:1  labels, hints, captions
         --bar-empty:  #3a3a3a        visible "off" band on dark bg
         --bar-work:   #1e6640        clear green "work" band

       Light mode: greys are DARK — enough contrast on white.
         --text-muted: #606060  6.0:1  secondary text
         --text-dim:   #999999  2.8:1  labels/hints (large/caps only)
         --bar-empty:  #e8e8e8        subtle "off" band on white bg
         --bar-work:   #d4edda        soft green "work" band
    ─────────────────────────────────────────────────────────────── */
    :root[data-theme="dark"] {
      --bg: #0a0a0a;
      --bg-subtle: #111111;
      --text: #ffffff;
      --text-muted: #f2f5f4;  /* near-white on black */
      --text-dim: #f2f5f4;    /* same — both levels light on dark */
      --border: #222222;
      --bar-empty: #5a5a5a;
      --bar-work: #1e6640;
      /* footer is inverted (white bg) — grey on white */
      --footer-city: #606060;
      --footer-region: #999999;
    }
    :root[data-theme="light"] {
      --bg: #ffffff;
      --bg-subtle: #fafafa;
      --text: #111111;
      --text-muted: #191932;  /* deep indigo on white */
      --text-dim: #5a5a8a;    /* mid blue-grey, WCAG AA 4.6:1 on white */
      --border: #ebebeb;
      --bar-empty: #b8b8b8;   /* clearly visible mid-grey on white */
      --bar-work: #6dba8e;    /* proper saturated green on white */
      /* footer is inverted (dark bg) — grey on dark, same as dark mode text-muted */
      --footer-city: #f2f5f4;
      --footer-region: #8a8a8a;
    }

    html {
      overflow-x: hidden; /* prevent horizontal scroll on mobile */
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      transition: background 0.3s, color 0.3s;
      overflow-x: hidden;
      max-width: 100vw;
    }

    /* Focus rings for keyboard navigation */
    :focus-visible {
      outline: 2px solid var(--text-muted);
      outline-offset: 2px;
      border-radius: 2px;
    }

    /* Skip to content link */
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      background: var(--text);
      color: var(--bg);
      padding: 8px 16px;
      font-size: var(--t-sm);
      z-index: 1000;
      border-radius: 0 0 4px 4px;
      text-decoration: none;
      transition: top 0.15s;
    }
    .skip-link:focus {
      top: 0;
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <main id="main-content">
    <slot />
  </main>
</body>
</html>
