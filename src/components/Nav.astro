---
// src/components/Nav.astro
---
<nav>
  <div class="nav-top">
    <a href="/" class="logo">whatisthetime<span class="logo-tld">.now</span></a>

    <div class="nav-search nav-search-desktop" id="nav-search">
      <input
        id="nav-search-input"
        class="nav-search-input"
        type="text"
        placeholder="Search city…"
        autocomplete="off"
        spellcheck="false"
      />
      <div class="nav-ac" id="nav-ac"></div>
    </div>

    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
      <span class="toggle-label-dark">☀️ light</span>
      <span class="toggle-label-light">🌙 dark</span>
    </button>
  </div>

  <div class="nav-search nav-search-mobile" id="nav-search-mobile">
    <input
      id="nav-search-input-mobile"
      class="nav-search-input"
      type="text"
      placeholder="Search city…"
      autocomplete="off"
      spellcheck="false"
    />
    <div class="nav-ac" id="nav-ac-mobile"></div>
  </div>
</nav>

<style>
  nav {
    border-bottom: 1px solid var(--border);
  }

  .nav-top {
    padding: 14px var(--page-pad);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    min-height: 48px;
  }

  .logo {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.5px;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .logo-tld { opacity: 0.4; }

  /* ── City search ── */
  .nav-search {
    position: relative;
    flex: 1;
    max-width: 280px;
  }

  .nav-search-input {
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 16px; /* prevents iOS zoom on focus */
    font-family: inherit;
    padding: 6px 0;
    outline: none;
    transition: border-color 0.15s;
  }
  .nav-search-input:focus { border-color: var(--text-muted); }
  .nav-search-input::placeholder { color: var(--text-dim); font-size: var(--t-sm); }

  .nav-ac {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-top: none;
    z-index: 100;
    max-height: 260px;
    overflow-y: auto;
  }

  .nav-ac-item {
    padding: 12px 14px;
    cursor: pointer;
    font-size: var(--t-sm);
    color: var(--text);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .nav-ac-item:hover, .nav-ac-item.ac-active { background: var(--bar-empty); }
  .nav-ac-item span { font-size: var(--t-xs); color: var(--text-dim); }

  /* ── Theme toggle ── */
  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-muted);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: var(--t-xs);
    cursor: pointer;
    transition: border-color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
    min-height: 36px;
  }
  .theme-toggle:hover { border-color: var(--text-muted); }

  :root[data-theme="dark"]  .toggle-label-light { display: none; }
  :root[data-theme="light"] .toggle-label-dark  { display: none; }

  /* ── Mobile search row (below logo) ── */
  .nav-search-mobile {
    display: none;
    max-width: 100%;
    padding: 0 var(--page-pad) 12px;
  }

  /* ── Responsive ── */
  @media (max-width: 500px) {
    .nav-search-desktop { display: none; }
    .nav-search-mobile { display: block; }
  }
</style>

<script>
  import allCities from '../data/cities-client.ts';

  // ── Theme toggle
  const themeBtn = document.getElementById('theme-toggle')!;
  themeBtn.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // ── City search (wire up both desktop + mobile inputs)
  function wireSearch(inputId: string, acId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const ac = document.getElementById(acId);
    if (!input || !ac) return;

    let activeIndex = -1;

    function showAc(q: string) {
      ac!.textContent = '';
      activeIndex = -1;
      if (!q.trim()) return;
      const matches = allCities
        .filter(c =>
          c.name.toLowerCase().includes(q.toLowerCase()) ||
          c.country.toLowerCase().includes(q.toLowerCase())
        )
        .slice(0, 8);

      ac!.setAttribute('role', 'listbox');
      matches.forEach((c, i) => {
        const div = document.createElement('div');
        div.className = 'nav-ac-item';
        div.dataset.slug = c.slug;
        div.setAttribute('role', 'option');
        div.id = `${acId}-opt-${i}`;
        div.textContent = `${c.name}, `;
        const span = document.createElement('span');
        span.textContent = c.country;
        div.appendChild(span);
        ac!.appendChild(div);
      });
    }

    function selectItem(index: number) {
      const items = ac!.querySelectorAll('.nav-ac-item');
      items.forEach((el, i) => {
        el.classList.toggle('ac-active', i === index);
      });
      if (items[index]) {
        input.setAttribute('aria-activedescendant', items[index].id);
      }
    }

    input.setAttribute('role', 'combobox');
    input.setAttribute('aria-autocomplete', 'list');
    input.setAttribute('aria-expanded', 'false');
    input.setAttribute('aria-controls', acId);

    input.addEventListener('input', () => {
      showAc(input.value);
      input.setAttribute('aria-expanded', ac!.children.length > 0 ? 'true' : 'false');
    });
    input.addEventListener('keydown', (e) => {
      const items = ac!.querySelectorAll('.nav-ac-item');
      if (e.key === 'Escape') { ac!.textContent = ''; input.blur(); }
      else if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = Math.min(activeIndex + 1, items.length - 1);
        selectItem(activeIndex);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
        selectItem(activeIndex);
      } else if (e.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
        e.preventDefault();
        window.location.href = '/' + (items[activeIndex] as HTMLElement).dataset.slug;
      }
    });
    input.addEventListener('blur', () => {
      setTimeout(() => { ac!.textContent = ''; input.setAttribute('aria-expanded', 'false'); }, 150);
    });

    ac.addEventListener('mousedown', (e) => {
      const item = (e.target as HTMLElement).closest('.nav-ac-item') as HTMLElement | null;
      if (!item) return;
      e.preventDefault();
      window.location.href = '/' + item.dataset.slug;
    });
  }

  wireSearch('nav-search-input', 'nav-ac');
  wireSearch('nav-search-input-mobile', 'nav-ac-mobile');
</script>
