---
// src/components/Footer.astro
const regions = [
  {
    label: 'Americas',
    cities: [
      { slug: 'new-york-city', name: 'New York' },
      { slug: 'los-angeles', name: 'Los Angeles' },
      { slug: 'chicago', name: 'Chicago' },
      { slug: 'toronto', name: 'Toronto' },
      { slug: 'sao-paulo', name: 'São Paulo' },
      { slug: 'buenos-aires', name: 'Buenos Aires' },
      { slug: 'mexico-city', name: 'Mexico City' },
      { slug: 'bogota', name: 'Bogotá' },
      { slug: 'lima', name: 'Lima' },
    ],
  },
  {
    label: 'Europe',
    cities: [
      { slug: 'london', name: 'London' },
      { slug: 'paris', name: 'Paris' },
      { slug: 'berlin', name: 'Berlin' },
      { slug: 'amsterdam', name: 'Amsterdam' },
      { slug: 'madrid', name: 'Madrid' },
      { slug: 'rome', name: 'Rome' },
      { slug: 'stockholm', name: 'Stockholm' },
      { slug: 'copenhagen', name: 'Copenhagen' },
      { slug: 'oslo', name: 'Oslo' },
      { slug: 'zurich', name: 'Zurich' },
      { slug: 'nuuk', name: 'Nuuk' },
    ],
  },
  {
    label: 'Middle East & Africa',
    cities: [
      { slug: 'dubai', name: 'Dubai' },
      { slug: 'istanbul', name: 'Istanbul' },
      { slug: 'tel-aviv', name: 'Tel Aviv' },
      { slug: 'tehran', name: 'Tehran' },
      { slug: 'cairo', name: 'Cairo' },
      { slug: 'lagos', name: 'Lagos' },
      { slug: 'nairobi', name: 'Nairobi' },
      { slug: 'johannesburg', name: 'Johannesburg' },
      { slug: 'casablanca', name: 'Casablanca' },
      { slug: 'addis-ababa', name: 'Addis Ababa' },
      { slug: 'accra', name: 'Accra' },
      { slug: 'dar-es-salaam', name: 'Dar es Salaam' },
    ],
  },
  {
    label: 'Asia & Pacific',
    cities: [
      { slug: 'tokyo', name: 'Tokyo' },
      { slug: 'beijing', name: 'Beijing' },
      { slug: 'shanghai', name: 'Shanghai' },
      { slug: 'hong-kong', name: 'Hong Kong' },
      { slug: 'singapore', name: 'Singapore' },
      { slug: 'seoul', name: 'Seoul' },
      { slug: 'mumbai', name: 'Mumbai' },
      { slug: 'delhi', name: 'Delhi' },
      { slug: 'bangkok', name: 'Bangkok' },
      { slug: 'jakarta', name: 'Jakarta' },
      { slug: 'taipei', name: 'Taipei' },
      { slug: 'sydney', name: 'Sydney' },
      { slug: 'auckland', name: 'Auckland' },
    ],
  },
];

const navLinks = [
  { href: '/now', label: 'Now' },
  { href: '/timezones', label: 'Timezone Map' },
  { href: '/summertime', label: 'Is It Summertime?' },
  { href: '/my-timezone', label: 'My Timezone' },
  { href: '/articles/jet-lag', label: 'Jet Lag' },
  { href: '/widget', label: 'Clock Widget' },
  { href: '/cities', label: 'All 990 Cities' },
];
---
<footer>
  <!-- Navigation links -->
  <div class="footer-nav">
    {navLinks.map(link => (
      <a href={link.href} class="footer-nav-link">{link.label}</a>
    ))}
  </div>

  <div class="footer-grid">
    {regions.map(region => (
      <div class="footer-region">
        <span class="region-label">{region.label}</span>
        {region.cities.map(c => (
          <a href={`/${c.slug}`} class="city-link">{c.name}</a>
        ))}
      </div>
    ))}
  </div>

  <div class="footer-legal">
    <a href="/privacy" class="footer-legal-link">Privacy</a>
    <a href="/terms" class="footer-legal-link">Terms</a>
    <a href="/affiliate-disclosure" class="footer-legal-link">Affiliate Disclosure</a>
    <a href="/about" class="footer-legal-link">About</a>
    <a href="/contact" class="footer-legal-link">Contact</a>
  </div>

  <div class="footer-inner">
    <a href="/" class="footer-brand">whatisthetime<span class="tld">.now</span></a>
    <span class="footer-meta">990 cities · 245 countries · © {new Date().getFullYear()}</span>
  </div>
</footer>

<style>
  footer {
    background: var(--text);
    color: var(--bg);
    padding: 40px var(--page-pad) 32px;
    margin-top: 0;
    transition: background 0.3s, color 0.3s;
  }

  /* ── Footer nav ───────────────────────────────────────── */
  .footer-nav {
    display: flex;
    gap: 24px;
    padding-bottom: 24px;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--footer-region);
    flex-wrap: wrap;
  }

  .footer-nav-link {
    font-size: var(--t-sm);
    color: var(--footer-city);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .footer-nav-link:hover { color: var(--bg); }

  /* ── City grid ───────────────────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px 24px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--footer-region);
    margin-bottom: 28px;
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 16px;
    }
  }

  @media (max-width: 400px) {
    .footer-grid { grid-template-columns: 1fr; }
  }

  .footer-region {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .region-label {
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--footer-region);
    margin-bottom: 4px;
  }

  .city-link {
    color: var(--footer-city);
    text-decoration: none;
    font-size: var(--t-sm);
    line-height: 1.5;
    transition: color 0.15s;
  }
  .city-link:hover { color: var(--bg); }

  /* ── Legal links ───────────────────────────────────── */
  .footer-legal {
    display: flex;
    gap: 20px;
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--footer-region);
    flex-wrap: wrap;
  }

  .footer-legal-link {
    font-size: var(--t-xs);
    color: var(--footer-region);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-legal-link:hover { color: var(--footer-city); }

  /* ── Brand bar ───────────────────────────────────────── */
  .footer-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-variation-settings: 'wght' 800, 'opsz' 50;
    font-size: clamp(1.5rem, 6vw, 3rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--bg);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .footer-brand:hover { opacity: 0.7; }

  .tld { opacity: 0.4; }

  .footer-meta {
    font-size: var(--t-xs);
    opacity: 0.4;
    letter-spacing: 0.04em;
    align-self: flex-end;
    padding-bottom: 4px;
  }
</style>
