---
// src/components/ClockHero.astro
import { getCurrentTime, formatUtcOffset, getDSTTransitions, getUtcOffsetMinutes } from '../lib/timezone.ts';
import type { CityEntry } from '../data/cities.ts';
import SunCalc from 'suncalc';

export interface Props {
  city: CityEntry;
}

const { city } = Astro.props;
const time = getCurrentTime(city.timezone);
const pad = (n: number) => String(n).padStart(2, '0');
const initialTime = `${pad(time.hours)}:${pad(time.minutes)}:${pad(time.seconds)}`;
const utcLabel = formatUtcOffset(time.utcOffsetMinutes);

// DST status
const year = new Date().getFullYear();
const dst = getDSTTransitions(city.timezone, year);
const isInDST = dst.hasDST && time.utcOffsetMinutes === dst.summerOffset;

// Week number (ISO 8601: week starts Monday, W1 contains first Thursday)
const now = new Date();
const localDate = new Date(now.toLocaleString('en-US', { timeZone: city.timezone }));
const d = new Date(Date.UTC(localDate.getFullYear(), localDate.getMonth(), localDate.getDate()));
d.setUTCDate(d.getUTCDate() + 4 - (d.getUTCDay() || 7)); // nearest Thursday
const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
const weekNum = Math.ceil((((d.getTime() - yearStart.getTime()) / 86400000) + 1) / 7);

// Sunrise/sunset (using city lat/lng)
let sunriseStr = '';
let sunsetStr = '';
if (city.lat !== 0 || city.lng !== 0) {
  const sunTimes = SunCalc.getTimes(now, city.lat, city.lng);
  const fmt = (d: Date) => {
    try {
      return new Intl.DateTimeFormat('en-US', {
        timeZone: city.timezone,
        hour: '2-digit', minute: '2-digit',
        hour12: false,
      }).format(d);
    } catch { return ''; }
  };
  sunriseStr = fmt(sunTimes.sunrise);
  sunsetStr = fmt(sunTimes.sunset);
}
---

<section class="clock-section">
  <div class="city-label">
    {city.name}, {city.country} · {utcLabel}
    <button class="star-btn" id="star-btn" data-slug={city.slug} data-name={city.name} data-tz={city.timezone} data-country={city.country} aria-label="Save to My Cities">&#9734;</button>
  </div>
  <div
    id="clock"
    data-timezone={city.timezone}
  >{initialTime}</div>
  <div class="date-line" id="date-line">{time.dateString}</div>

  <div class="meta-row">
    <span class="meta-item">W{weekNum}</span>
    {sunriseStr && <span class="meta-item">↑ {sunriseStr}</span>}
    {sunsetStr && <span class="meta-item">↓ {sunsetStr}</span>}
    {dst.hasDST ? (
      isInDST
        ? <span class="meta-item dst-badge dst-active">DST</span>
        : <span class="meta-item dst-badge dst-standard">STD</span>
    ) : (
      <span class="meta-item dst-badge dst-none">No DST</span>
    )}
  </div>
</section>

<style>
  .clock-section {
    padding: 48px var(--page-pad) 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .city-label {
    font-size: var(--t-base);
    color: var(--text-muted);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .star-btn {
    background: none;
    border: none;
    font-size: 1.2em;
    cursor: pointer;
    color: var(--text-dim);
    padding: 0;
    line-height: 1;
    transition: color 0.15s;
  }
  .star-btn:hover { color: var(--text); }
  .star-btn.starred { color: #f5a623; }

  #clock {
    font-family: var(--font-display);
    font-size: var(--t-display);
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--text);
    font-variation-settings: 'wght' 800, 'opsz' 50;
    font-variant-numeric: tabular-nums;
    text-align: left;
    width: 100%;
  }

  .date-line {
    font-size: var(--t-base);
    color: var(--text-muted);
    margin-top: 16px;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .meta-item {
    font-size: var(--t-xs);
    font-family: var(--font-mono);
    color: var(--text-dim);
    letter-spacing: 0.03em;
  }

  .dst-badge {
    padding: 2px 6px;
    border-radius: 3px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dst-active {
    color: #4caf50;
    border: 1px solid #4caf50;
  }

  .dst-standard {
    color: var(--text-dim);
    border: 1px solid var(--border);
  }

  .dst-none {
    color: var(--text-dim);
    border: 1px solid var(--border);
  }
</style>

<script>
  function pad(n: number): string {
    return String(n).padStart(2, '0');
  }

  const clockEl = document.getElementById('clock')!;
  const dateEl = document.getElementById('date-line')!;
  const timezone = clockEl.dataset.timezone!;

  function tick() {
    const now = new Date();
    const timeParts = new Intl.DateTimeFormat('en-US', {
      timeZone: timezone,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: false,
    }).formatToParts(now);

    const get = (type: string) =>
      timeParts.find(p => p.type === type)?.value ?? '00';

    // Intl returns '24' at midnight with hour12:false — normalise to '00'
    const hour = get('hour') === '24' ? '00' : get('hour');
    clockEl.textContent = `${hour}:${get('minute')}:${get('second')}`;

    dateEl.textContent = new Intl.DateTimeFormat('en-US', {
      timeZone: timezone,
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(now);
  }

  tick();
  setInterval(tick, 1000);

  // Star / My Cities
  const starBtn = document.getElementById('star-btn') as HTMLButtonElement;
  if (starBtn) {
    const slug = starBtn.dataset.slug!;
    const saved: string[] = JSON.parse(localStorage.getItem('myCities') || '[]');
    if (saved.includes(slug)) {
      starBtn.textContent = '\u2605';
      starBtn.classList.add('starred');
    }
    starBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const current: string[] = JSON.parse(localStorage.getItem('myCities') || '[]');
      if (current.includes(slug)) {
        localStorage.setItem('myCities', JSON.stringify(current.filter(s => s !== slug)));
        starBtn.textContent = '\u2606';
        starBtn.classList.remove('starred');
      } else {
        current.unshift(slug);
        localStorage.setItem('myCities', JSON.stringify(current.slice(0, 8)));
        starBtn.textContent = '\u2605';
        starBtn.classList.add('starred');
      }
    });
  }
</script>
